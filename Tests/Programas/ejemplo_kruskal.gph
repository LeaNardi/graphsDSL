g := graph [
  ("A", [("B", 7), ("D", 5)]),
  ("B", [("C", 8), ("D", 9), ("E", 7)]),
  ("C", [("E", 5)]),
  ("D", [("E", 15), ("F", 6)]),
  ("E", [("F", 8), ("G", 9)]),
  ("F", [("G", 11)])
];

uf := unionfind [
  ("A", "A"), ("B", "B"), ("C", "C"),
  ("D", "D"), ("E", "E"), ("F", "F"), ("G", "G")
];

edges := sortByWeight(getEdges(g));
mst := graph [];
pending := edges;

while len(pending) > 0 do
  edge_elem := head(pending);
  pending := tail(pending);

  u := getNode1(edge_elem);
  v := getNode2(edge_elem);
  w := getWeight(edge_elem);
  rep_u := find(u, uf);
  rep_v := find(v, uf);

  cond !(rep_u == rep_v) then
    mst := addEdge(mst, u, v, w) ;
    uf := union(u, v, uf)
  else
    skip
  end
end