// Test program demonstrating the complete type system
// Int, Float, Bool, String, Node, Edge, Graph, List, Queue

// Basic literals
x := 42;
y := 3.14;
flag := true;
message := "Hello World";
node1 := "A";

// Arithmetic with mixed types
sum := x + y;  // Should promote to Float: 45.14

// Boolean operations
result := flag && (x > 30);  // Should be true

// Graph construction with Float weights
g := graph [
    ("A", [("B", 2.5), ("C", 1.0)]),
    ("B", [("A", 2.5)]),
    ("C", [("A", 1.0)])
];

// Edge with Float weight
edge1 := edge("D", "E", 4.2);

// Lists with mixed types
numbers := [1, 2, 3];
nodes := ["X", "Y", "Z"];

// Queue construction
q := queue [1, 2, 3, 4];

// Add operations
g2 := addNode(g, "D");
g3 := addEdge(g2, "B", "D", 1.8);

print x;
print y;
print flag;
print message;
print sum;
print result