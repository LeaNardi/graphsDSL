{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "GraphsDSL",
  "scopeName": "source.graphsdsl",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#variables"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-dash.graphsdsl",
          "match": "--.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.graphsdsl",
          "match": "\\b(cond|then|else|end|while|do|for|in|skip|print)\\b"
        },
        {
          "name": "keyword.other.graphsdsl",
          "match": "\\b(graph|edge|queue|emptyList|emptyQueue)\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.graphsdsl",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.graphsdsl",
          "match": "\\\\."
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.graphsdsl",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.graphsdsl",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.graphsdsl",
          "match": ":="
        },
        {
          "name": "keyword.operator.comparison.graphsdsl",
          "match": "(==|<|>|=node)"
        },
        {
          "name": "keyword.operator.logical.graphsdsl",
          "match": "(&&|\\|\\|)"
        },
        {
          "name": "keyword.operator.arithmetic.graphsdsl",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.unary.graphsdsl",
          "match": "!"
        },
        {
          "name": "keyword.operator.ternary.graphsdsl",
          "match": "[?:]"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.graphsdsl",
          "match": "\\b(addNode|deleteNode|addEdge|deleteEdge|complement|union|intersection|getEdges|adjacentNodes|getWeight|getNode1|getNode2|len|head|tail|add|sortByWeight|headEdge|tailEdges|queueLen|enqueue|dequeue|dequeueNode|isEmpty|unionFind|find|esCiclico|esConexo|inList|isEmptyList)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.graphsdsl",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.graphsdsl",
          "match": "\\b[a-zA-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
